{
  "manifest_version": 3,
  "name": "Link's Fairy",
  "version": "0.2.0",
  "description": "Analiza la seguridad de la web actual con un agente remoto.",
  "permissions": [
    "storage",
    "contentSettings",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "scripts/background.js"
  },
  "action": {
    "default_title": "Link's Fairy",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/fairy-status-loading-16.png",
      "32": "images/fairy-status-loading-32.png",
      "48": "images/fairy-status-loading-48.png",
      "128": "images/fairy-status-loading-128.png"
    }
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "scripts/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  }
}
